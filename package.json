{
  "name": "node_pdf",
  "version": "1.0.0",
  "description": "Merge PDF files or convert ordered JPGs into a PDF, usable as a CLI or as a Node.js library.",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "bin": {
    "node-pdf-merge": "./bin/cli.js",
    "node-images-to-pdf": "./bin/images-to-pdf-cli.js"
  },
  "files": [
    "index.js",
    "lib",
    "bin"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .js,.mjs",
    "lint:fix": "eslint . --ext .js,.mjs --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky",
    "build:merge": "pkg bin/cli.js --targets node22-win-x64,node22-linux-x64,node22-macos-x64 --output dist/node-pdf-merge",
    "build:images-to-pdf": "pkg bin/images-to-pdf-cli.js --targets node22-win-x64,node22-linux-x64,node22-macos-x64 --output dist/node-images-to-pdf",
    "build": "npm run build:merge && npm run build:images-to-pdf"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ribeirohugo/node_pdf.git"
  },
  "keywords": [
    "pdf",
    "merge",
    "pdf-merge",
    "jpg",
    "image-to-pdf",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ribeirohugo/node_pdf/issues"
  },
  "homepage": "https://github.com/ribeirohugo/node_pdf#readme",
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdf-merger-js": "^5.1.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0",
    "eslint": "^10.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.9.5"
  }
}
